# Drizzle
DATABASE_URL=local.db

# Game server (port for Bun WS)
WS_PORT=8080
# Admin control page token. Required for /admin WebSocket control actions.
ADMIN_TOKEN=change-me

# ACK barrier timing
# T_ACK: ms each player stays armed (all N must overlap within window to fire)
T_ACK=3000
# WRONG_PENALTY: ms cooldown after wrong submit
WRONG_PENALTY=3000
# CORRUPTION_CHANCE: per-fragment corruption probability (0.0 - 1.0)
CORRUPTION_CHANCE=0.4
# REVEAL_MS: how long a delivered fragment stays visible before it vanishes (flash window)
REVEAL_MS=15000
# CHOICE_COUNT: number of similar choices shown after the packet vanishes
CHOICE_COUNT=8
# CHOICE_WRONG_PENALTY: ms cooldown after choosing the wrong fragment option
CHOICE_WRONG_PENALTY=1200
# RECONNECT_GRACE_MS: how long to preserve a player slot after refresh/disconnect
RECONNECT_GRACE_MS=5000
