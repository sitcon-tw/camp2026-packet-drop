# Drizzle
DATABASE_URL=local.db

# Game server (port for Bun WS)
WS_PORT=8080

# ACK barrier timing
# T_ACK: ms each player stays armed (all N must overlap within window to fire)
T_ACK=600000
# WRONG_PENALTY: ms cooldown after wrong submit
WRONG_PENALTY=3000
# CORRUPTION_CHANCE: per-fragment corruption probability (0.0 - 1.0)
CORRUPTION_CHANCE=0.4
# REVEAL_MS: how long a delivered fragment stays visible before it vanishes (flash window)
REVEAL_MS=15000
